#!/usr/bin/env bash
# duckport — 服务管理 CLI
#
# 用法：
#   duckport status                      # 服务总览 + 水位
#   duckport start   [<实例>|all]        # 启动（默认 all）
#   duckport stop    [<实例>|all]        # 停止（默认 all）
#   duckport restart [<实例>|all]        # 重启（默认 all）
#   duckport logs    <实例>|server|all   # 实时日志
#   duckport ingestor list               # 列出所有实例
#   duckport ingestor add  <实例>        # 新增实例
#   duckport ingestor rm   <实例>        # 删除实例
#   duckport loadhist [<实例>]           # 补历史数据
#   duckport upgrade                     # 更新环境

set -euo pipefail

DEPLOY_OPT="/opt/duckport"
DEPLOY_BIN="$DEPLOY_OPT/bin"
INGESTORS_DIR="$DEPLOY_OPT/ingestors"
# 从 deploy.sh 写入的持久化路径读取，回退到默认值
REPO_DIR="$(cat "$DEPLOY_OPT/repo_dir" 2>/dev/null || echo "/w/code/duckport-rs")"

BOLD='\033[1m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; RED='\033[0;31m'; DIM='\033[2m'; NC='\033[0m'

# ─── 工具 ──────────────────────────────────────────────────────────────────────

_require_root() {
  [[ $EUID -eq 0 ]] || { echo -e "${RED}需要 root 权限，请用 sudo${NC}"; exit 1; }
}

_svc_status_label() {
  local state
  state=$(systemctl is-active "duckport-ingestor@$1" 2>/dev/null || echo "inactive")
  case "$state" in
    active)   echo -e "${GREEN}● active${NC}" ;;
    inactive) echo -e "${DIM}○ inactive${NC}" ;;
    failed)   echo -e "${RED}✗ failed${NC}" ;;
    *)        echo -e "${YELLOW}? ${state}${NC}" ;;
  esac
}

_list_instances() {
  find "$INGESTORS_DIR" -maxdepth 2 -name "config.env" 2>/dev/null \
    | sed "s|$INGESTORS_DIR/||;s|/config.env||" | sort
}

_instance_python() {
  echo "$INGESTORS_DIR/$1/.venv/bin/python3"
}

_instance_exec() {
  local cfg="$INGESTORS_DIR/$1/config.env"
  grep '^INGESTOR_EXEC=' "$cfg" 2>/dev/null | cut -d= -f2 | tr -d '"' \
    || echo "binance-ingestor"
}

_resolve_instances() {
  local arg="${1:-all}"
  if [[ "$arg" == "all" || -z "$arg" ]]; then
    _list_instances
  else
    echo "$arg"
  fi
}

# ─── status ───────────────────────────────────────────────────────────────────

cmd_status() {
  echo -e "\n${BOLD}duckport-server${NC}"
  local sv_state
  sv_state=$(systemctl is-active duckport-server 2>/dev/null || echo "inactive")
  printf "  %-22s %s\n" "duckport-server" \
    "$(case $sv_state in active) echo -e "${GREEN}● active${NC}";; *) echo -e "${DIM}○ $sv_state${NC}";; esac)"

  echo -e "\n${BOLD}Ingestors${NC}"
  local instances
  instances=$(_list_instances)
  if [[ -z "$instances" ]]; then
    echo -e "  ${DIM}（无已注册实例）${NC}"
  else
    while IFS= read -r inst; do
      local exec_name
      exec_name=$(_instance_exec "$inst")
      printf "  %-22s %s  ${DIM}[%s]${NC}\n" \
        "$inst" "$(_svc_status_label "$inst")" "$exec_name"
    done <<< "$instances"
  fi

  echo -e "\n${BOLD}数据水位${NC}"
  if ! nc -z localhost 50051 2>/dev/null; then
    echo -e "  ${DIM}duckport-server 未监听 :50051${NC}\n"
    return
  fi

  while IFS= read -r inst; do
    local py cfg
    py=$(_instance_python "$inst")
    cfg="$INGESTORS_DIR/$inst/config.env"
    [[ -x "$py" && -f "$cfg" ]] || continue

    "$py" - "$inst" "$cfg" << 'PYEOF' 2>/dev/null || true
import sys
from binance_ingestor.duckport_client import DuckportClient
from datetime import datetime, timezone

inst, cfg = sys.argv[1], sys.argv[2]
sources = []
for line in open(cfg):
    if line.startswith("DATA_SOURCES="):
        sources = [s.strip() for s in line.split("=",1)[1].strip().split(",")]

dc = DuckportClient(addr="localhost:50051", schema="data")
now = datetime.now(timezone.utc)
for mkt in sources:
    dt = dc.read_duck_time(mkt)
    if dt is None:
        print(f"  [{inst}] {mkt:<18}: None")
        continue
    age = now - dt
    h, r = divmod(int(age.total_seconds()), 3600)
    m = r // 60
    age_str = f"{h}h{m:02d}m" if h else f"{m}m"
    mark = "\033[0;32m✓\033[0m" if age.total_seconds() < 900 else "\033[1;33m⚠\033[0m"
    print(f"  [{inst}] {mkt:<18}: {dt.strftime('%Y-%m-%d %H:%M')} UTC  {mark} {age_str} ago")
dc.close()
PYEOF
  done <<< "$([ -z "$instances" ] && echo "" || echo "$instances")"
  echo ""
}

# ─── start / stop / restart ───────────────────────────────────────────────────

cmd_start() {
  _require_root
  local arg="${1:-all}"
  local instances
  instances=$(_resolve_instances "$arg")

  # server 优先
  if [[ "$arg" == "all" ]] || [[ "$arg" == "server" ]]; then
    systemctl start duckport-server
    echo -e "  ${GREEN}✓${NC} duckport-server started"
    sleep 2
  fi

  while IFS= read -r inst; do
    [[ -z "$inst" ]] && continue
    systemctl start "duckport-ingestor@$inst"
    echo -e "  ${GREEN}✓${NC} duckport-ingestor@$inst started"
  done <<< "$instances"
}

cmd_stop() {
  _require_root
  local arg="${1:-all}"
  local instances
  instances=$(_resolve_instances "$arg")

  # 先停 ingestor
  while IFS= read -r inst; do
    [[ -z "$inst" ]] && continue
    systemctl stop "duckport-ingestor@$inst" 2>/dev/null || true
    echo -e "  ${DIM}○${NC} duckport-ingestor@$inst stopped"
  done <<< "$instances"

  if [[ "$arg" == "all" ]] || [[ "$arg" == "server" ]]; then
    systemctl stop duckport-server 2>/dev/null || true
    echo -e "  ${DIM}○${NC} duckport-server stopped"
  fi
}

cmd_restart() {
  _require_root
  local arg="${1:-all}"
  cmd_stop "$arg"
  sleep 1
  cmd_start "$arg"
}

# ─── logs ─────────────────────────────────────────────────────────────────────

cmd_logs() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    echo "用法: duckport logs <实例名>|server|all"; exit 1
  fi
  case "$target" in
    server)
      exec journalctl -u duckport-server -f --no-hostname -o short-iso ;;
    all)
      local units=("-u" "duckport-server")
      while IFS= read -r inst; do
        [[ -n "$inst" ]] && units+=("-u" "duckport-ingestor@$inst")
      done <<< "$(_list_instances)"
      exec journalctl "${units[@]}" -f --no-hostname -o short-iso ;;
    *)
      exec journalctl -u "duckport-ingestor@$target" -f --no-hostname -o short-iso ;;
  esac
}

# ─── ingestor list ────────────────────────────────────────────────────────────

cmd_ingestor_list() {
  echo -e "\n${BOLD}已注册的 Ingestor 实例${NC}"
  local instances
  instances=$(_list_instances)
  if [[ -z "$instances" ]]; then
    echo -e "  ${DIM}（无）${NC}\n"; return
  fi

  printf "  ${BOLD}%-22s %-18s %-20s %s${NC}\n" "实例名" "状态" "执行程序" "数据源"
  while IFS= read -r inst; do
    local cfg="$INGESTORS_DIR/$inst/config.env"
    local exec_name sources
    exec_name=$(_instance_exec "$inst")
    sources=$(grep '^DATA_SOURCES=' "$cfg" 2>/dev/null | cut -d= -f2 || echo "-")
    printf "  %-22s %-28s %-20s %s\n" \
      "$inst" "$(_svc_status_label "$inst")" "$exec_name" "$sources"
  done <<< "$instances"
  echo ""
}

# ─── ingestor add ─────────────────────────────────────────────────────────────

cmd_ingestor_add() {
  _require_root
  local name="${1:-}"
  [[ -n "$name" ]] || { echo "用法: duckport ingestor add <实例名>"; exit 1; }

  local inst_dir="$INGESTORS_DIR/$name"
  local cfg="$inst_dir/config.env"

  if [[ -d "$inst_dir" ]]; then
    echo -e "${YELLOW}实例 '$name' 已存在：$inst_dir${NC}"
    echo "如需重建，请先执行: duckport ingestor rm $name"
    exit 1
  fi

  mkdir -p "$inst_dir"
  echo -e "${BOLD}创建实例：$name${NC}"

  # 询问基本配置
  read -rp "  交易所 / 包名   (默认 binance-ingestor): " PKG
  PKG="${PKG:-binance-ingestor}"
  read -rp "  可执行命令名    (默认 ${PKG##*/}): " EXEC_CMD
  EXEC_CMD="${EXEC_CMD:-${PKG##*/}}"
  read -rp "  K 线周期        (默认 5m): " IV
  IV="${IV:-5m}"
  read -rp "  DATA_SOURCES    (默认 usdt_perp,usdt_spot): " DS
  DS="${DS:-usdt_perp,usdt_spot}"
  read -rp "  START_DATE      (默认 2021-01-01): " SD
  SD="${SD:-2021-01-01}"
  read -rp "  PROXY_URL       (留空跳过): " PX
  read -rp "  ENABLE_WS       (默认 false): " WS
  WS="${WS:-false}"

  cat > "$cfg" << EOF
# 实例：$name
INGESTOR_EXEC=${EXEC_CMD}
DUCKPORT_ADDR=localhost:50051
DUCKPORT_SCHEMA=data
KLINE_INTERVAL=${IV}
PARQUET_DIR=/data/duckport/pqt
DATA_SOURCES=${DS}
CONCURRENCY=2
RETENTION_ENABLED=false
START_DATE=${SD}
PROXY_URL=${PX}
ENABLE_WS=${WS}
RESOURCE_PATH=/data/duckport/hist
EOF

  # 安装 Python 包
  echo -e "\n  安装 Python 环境..."
  export PATH="$HOME/.local/bin:$PATH"
  PYTHON_BIN=$(command -v python3.12 2>/dev/null || command -v python3)
  PYTHON_VER=$("$PYTHON_BIN" --version | grep -oP '\d+\.\d+')
  uv venv --python "$PYTHON_VER" "$inst_dir/.venv" -q

  if [[ "$PKG" == "binance-ingestor" && -d "$REPO_DIR/ingestor" ]]; then
    uv pip install -e "$REPO_DIR/ingestor/" --python "$inst_dir/.venv/bin/python3" -q
  else
    uv pip install "$PKG" --python "$inst_dir/.venv/bin/python3" -q
  fi

  # 注册并 enable systemd 实例
  systemctl daemon-reload
  systemctl enable "duckport-ingestor@$name"
  echo -e "\n  ${GREEN}✓${NC} 实例 '$name' 已创建"
  echo -e "  配置文件：$cfg"
  echo -e "  启动：${BOLD}duckport start $name${NC}"
}

# ─── ingestor rm ──────────────────────────────────────────────────────────────

cmd_ingestor_rm() {
  _require_root
  local name="${1:-}"
  [[ -n "$name" ]] || { echo "用法: duckport ingestor rm <实例名>"; exit 1; }

  local inst_dir="$INGESTORS_DIR/$name"
  [[ -d "$inst_dir" ]] || { echo -e "${RED}实例 '$name' 不存在${NC}"; exit 1; }

  read -rp "确认删除实例 '$name'？[y/N] " CONFIRM
  [[ "$CONFIRM" =~ ^[Yy]$ ]] || { echo "已取消"; exit 0; }

  systemctl stop "duckport-ingestor@$name"  2>/dev/null || true
  systemctl disable "duckport-ingestor@$name" 2>/dev/null || true
  rm -rf "$inst_dir"
  echo -e "  ${GREEN}✓${NC} 实例 '$name' 已删除"
}

# ─── loadhist ─────────────────────────────────────────────────────────────────

cmd_loadhist() {
  _require_root
  local name="${1:-}"
  local instances

  if [[ -n "$name" ]]; then
    instances="$name"
  else
    instances=$(_list_instances)
    [[ -n "$instances" ]] || { echo -e "${RED}无已注册实例${NC}"; exit 1; }
  fi

  while IFS= read -r inst; do
    [[ -z "$inst" ]] && continue
    local py cfg
    py=$(_instance_python "$inst")
    cfg="$INGESTORS_DIR/$inst/config.env"
    [[ -x "$py" && -f "$cfg" ]] || { echo -e "${YELLOW}跳过 $inst（环境不完整）${NC}"; continue; }

    echo -e "\n${BOLD}▶ loadhist — $inst${NC}"
    echo -e "  ${YELLOW}⚠ 停止 ingestor 以独占 staging 表${NC}"
    systemctl stop "duckport-ingestor@$inst" 2>/dev/null || true

    INGESTOR_ENV_FILE="$cfg" \
      "$INGESTORS_DIR/$inst/.venv/bin/loadhist" && \
      echo -e "  ${GREEN}✓ loadhist 完成${NC}" || \
      echo -e "  ${RED}✗ loadhist 失败${NC}"

    systemctl start "duckport-ingestor@$inst"
    echo -e "  ${GREEN}✓${NC} duckport-ingestor@$inst 已恢复"
  done <<< "$instances"
}

# ─── upgrade ──────────────────────────────────────────────────────────────────

cmd_upgrade() {
  _require_root
  [[ -d "$REPO_DIR/.git" ]] || { echo -e "${RED}未找到仓库：$REPO_DIR${NC}"; exit 1; }
  echo -e "${BOLD}升级环境...${NC}"
  git -C "$REPO_DIR" pull --ff-only
  bash "$REPO_DIR/deploy.sh"
  echo -e "\n  ${YELLOW}环境已更新，如需生效：${NC}"
  echo -e "  duckport restart"
}

# ─── help ─────────────────────────────────────────────────────────────────────

cmd_help() {
  echo -e "
${BOLD}duckport${NC} — duckport-rs 服务管理

${BOLD}服务控制：${NC}
  duckport ${CYAN}status${NC}                        服务总览 + 数据水位
  duckport ${CYAN}start${NC}   [实例名|all]           启动（默认 all）
  duckport ${CYAN}stop${NC}    [实例名|all]           停止（默认 all）
  duckport ${CYAN}restart${NC} [实例名|all]           重启（默认 all）
  duckport ${CYAN}logs${NC}    <实例名|server|all>    实时日志

${BOLD}Ingestor 管理：${NC}
  duckport ${CYAN}ingestor list${NC}                  列出所有实例
  duckport ${CYAN}ingestor add${NC}  <实例名>          新增实例（交互式）
  duckport ${CYAN}ingestor rm${NC}   <实例名>          删除实例

${BOLD}数据操作：${NC}
  duckport ${CYAN}loadhist${NC} [实例名]              补历史数据（默认所有实例）

${BOLD}维护：${NC}
  duckport ${CYAN}upgrade${NC}                        git pull + 重新配置环境

${BOLD}示例：${NC}
  duckport ingestor add okx-5m        # 新增 OKX 5m 实例
  duckport start okx-5m               # 启动单个实例
  duckport logs okx-5m                # 查看该实例日志
  duckport loadhist binance-5m        # 对 binance-5m 补历史
"
}

# ─── dispatch ─────────────────────────────────────────────────────────────────

CMD="${1:-status}"
shift || true

case "$CMD" in
  status)   cmd_status ;;
  start)    cmd_start  "${1:-all}" ;;
  stop)     cmd_stop   "${1:-all}" ;;
  restart)  cmd_restart "${1:-all}" ;;
  logs)     cmd_logs   "${1:-}" ;;
  ingestor)
    SUB="${1:-list}"; shift || true
    case "$SUB" in
      list) cmd_ingestor_list ;;
      add)  cmd_ingestor_add  "${1:-}" ;;
      rm)   cmd_ingestor_rm   "${1:-}" ;;
      *)    echo -e "${RED}未知子命令：$SUB${NC}"; cmd_help; exit 1 ;;
    esac ;;
  loadhist) cmd_loadhist "${1:-}" ;;
  upgrade)  cmd_upgrade ;;
  help|-h|--help) cmd_help ;;
  *) echo -e "${RED}未知命令：$CMD${NC}"; cmd_help; exit 1 ;;
esac
