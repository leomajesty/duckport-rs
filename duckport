  duckport logs binance-5m            # 查看该实例日志
  duckport loadhist binance-5m        # 补历史数据
"
}

# ─── dispatch ─────────────────────────────────────────────────────────────────

CMD="${1:-status}"
shift || true

case "$CMD" in
  list)     cmd_list ;;
  install)  cmd_install "${1:-}" ;;
  rm)       cmd_rm      "${1:-}" ;;
  update)   cmd_update  "${1:-}" ;;
  config)   cmd_config  "${1:-}" ;;
  status)   cmd_status ;;
  start)    cmd_start   "${1:-server}" ;;
  stop)     cmd_stop    "${1:-all}" ;;
  restart)  cmd_restart "${1:-all}" ;;
  logs)     cmd_logs    "${1:-}" ;;
  loadhist) cmd_loadhist "${1:-}" ;;
  upgrade)  cmd_upgrade ;;
  help|-h|--help) cmd_help ;;
  *) echo -e "${RED}未知命令：$CMD${NC}"; cmd_help; exit 1 ;;
esac
