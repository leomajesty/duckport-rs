#!/usr/bin/env bash
# duckport — 服务管理 CLI
#
# 用法：
#   duckport list                        # 列出可用插件
#   duckport install <插件名>            # 安装插件实例
#   duckport rm      <实例名>            # 删除实例
#   duckport config  <实例名>            # 编辑实例配置
#   duckport status                      # 服务总览 + 水位
#   duckport start   [<实例>|all]        # 启动（默认 server）
#   duckport stop    [<实例>|all]        # 停止（默认 all）
#   duckport restart [<实例>|all]        # 重启（默认 all）
#   duckport logs    <实例>|server|all   # 实时日志
#   duckport update  <实例名>            # 更新插件（自动判断本地/GitHub）
#   duckport loadhist [<实例>]           # 补历史数据
#   duckport upgrade                     # 更新环境

set -euo pipefail

# ─── 平台检测 ─────────────────────────────────────────────────────────────────

OS=$(uname -s)    # Linux | Darwin

# macOS 用用户路径（无需 sudo），Linux 用系统路径
if [[ "$OS" == "Darwin" ]]; then
  DEPLOY_OPT="$HOME/.duckport"
  PLIST_DIR="$HOME/Library/LaunchAgents"
  LOG_DIR="$HOME/.duckport/logs"
  _DEFAULT_REPO="$HOME/code/duckport-rs"
else
  DEPLOY_OPT="/opt/duckport"
  PLIST_DIR=""   # Linux 用 systemd，不需要
  LOG_DIR="/opt/duckport/logs"
  _DEFAULT_REPO="/w/code/duckport-rs"
fi

DEPLOY_BIN="$DEPLOY_OPT/bin"
INGESTORS_DIR="$DEPLOY_OPT/ingestors"
# 从 deploy.sh 写入的持久化路径读取，回退到平台默认值
REPO_DIR="$(cat "$DEPLOY_OPT/repo_dir" 2>/dev/null || echo "$_DEFAULT_REPO")"

BOLD='\033[1m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; RED='\033[0;31m'; DIM='\033[2m'; NC='\033[0m'

# ─── 工具 ──────────────────────────────────────────────────────────────────────

_require_root() {
  # macOS 用户路径模式：所有操作在当前用户权限下即可完成
  [[ "$OS" == "Darwin" ]] && return
  [[ $EUID -eq 0 ]] || { echo -e "${RED}需要 root 权限，请用 sudo${NC}"; exit 1; }
}

# uv pip install 封装：清除 shell 代理（代理是给 ingestor 运行时用的，不用于包安装），
# 并支持 UV_INDEX_URL 环境变量指定 PyPI 镜像（如清华 https://pypi.tuna.tsinghua.edu.cn/simple/）
_uv_install() {
  HTTP_PROXY="" HTTPS_PROXY="" http_proxy="" https_proxy="" \
    uv pip install "$@"
}

# 将服务逻辑名转为 launchd label
_svc_label() {
  case "$1" in
    duckport-server)     echo "com.duckport.server" ;;
    duckport-ingestor@*) echo "com.duckport.ingestor.${1#duckport-ingestor@}" ;;
    *)                   echo "com.duckport.$1" ;;
  esac
}

# 查询服务是否 active，输出 "active" | "inactive"
_svc_is_active() {
  local svc="$1"
  if [[ "$OS" == "Linux" ]]; then
    systemctl is-active "$svc" 2>/dev/null || echo "inactive"
  else
    local label; label=$(_svc_label "$svc")
    # launchctl list <label> 有 "PID" 字段即为运行中
    if launchctl list "$label" 2>/dev/null | grep -q '"PID"'; then
      echo "active"
    else
      echo "inactive"
    fi
  fi
}

# 启动服务（macOS 用 bootstrap/kickstart 代替已废弃的 load）
_svc_start() {
  local svc="$1"
  if [[ "$OS" == "Linux" ]]; then
    systemctl start "$svc"
  else
    local label; label=$(_svc_label "$svc")
    local plist="$PLIST_DIR/${label}.plist"
    [[ -f "$plist" ]] || { echo -e "${RED}找不到 plist：$plist${NC}"; return 1; }
    local domain="gui/$(id -u)"
    # 若 plist 尚未注册，先 bootstrap（RunAtLoad=false 不会自动启动）
    if ! launchctl list "$label" &>/dev/null; then
      launchctl bootstrap "$domain" "$plist"
    fi
    # bootstrap 后或已注册时，kickstart 真正拉起进程
    launchctl kickstart "$domain/$label"
  fi
}

# 停止服务（macOS 用 bootout 代替已废弃的 unload）
_svc_stop() {
  local svc="$1"
  if [[ "$OS" == "Linux" ]]; then
    systemctl stop "$svc" 2>/dev/null || true
  else
    local label; label=$(_svc_label "$svc")
    local domain="gui/$(id -u)"
    launchctl bootout "$domain/$label" 2>/dev/null || true
  fi
}

_svc_status_label() {
  local state
  state=$(_svc_is_active "duckport-ingestor@$1")
  case "$state" in
    active)   echo -e "${GREEN}● active${NC}" ;;
    inactive) echo -e "${DIM}○ inactive${NC}" ;;
    failed)   echo -e "${RED}✗ failed${NC}" ;;
    *)        echo -e "${YELLOW}? ${state}${NC}" ;;
  esac
}

_list_instances() {
  find "$INGESTORS_DIR" -maxdepth 2 -name "config.env" 2>/dev/null \
    | sed "s|$INGESTORS_DIR/||;s|/config.env||" | sort
}

_instance_python() {
  echo "$INGESTORS_DIR/$1/.venv/bin/python3"
}

_instance_exec() {
  local cfg="$INGESTORS_DIR/$1/config.env"
  grep '^INGESTOR_EXEC=' "$cfg" 2>/dev/null | cut -d= -f2 | tr -d '"' \
    || echo "binance-ingestor"
}

_resolve_instances() {
  local arg="${1:-all}"
  if [[ "$arg" == "all" || -z "$arg" ]]; then
    _list_instances
  else
    echo "$arg"
  fi
}

# ─── status ───────────────────────────────────────────────────────────────────

cmd_status() {
  echo -e "\n${BOLD}duckport-server${NC}"
  local sv_state sv_label
  sv_state=$(_svc_is_active "duckport-server")
  if [[ "$sv_state" == "active" ]]; then
    sv_label="${GREEN}● active${NC}"
  else
    sv_label="${DIM}○ ${sv_state}${NC}"
  fi
  printf "  %-22s " "duckport-server"; echo -e "$sv_label"

  echo -e "\n${BOLD}Ingestors${NC}"
  local instances
  instances=$(_list_instances)
  if [[ -z "$instances" ]]; then
    echo -e "  ${DIM}（无已注册实例）${NC}"
  else
    while IFS= read -r inst; do
      local exec_name
      exec_name=$(_instance_exec "$inst")
      printf "  %-22s %s  ${DIM}[%s]${NC}\n" \
        "$inst" "$(_svc_status_label "$inst")" "$exec_name"
    done <<< "$instances"
  fi

  echo -e "\n${BOLD}数据水位${NC}"
  local server_port
  server_port=$(grep '^DUCKPORT_LISTEN_ADDR=' "$DEPLOY_OPT/server.env" 2>/dev/null \
    | cut -d: -f2 | tr -d '"' | tr -d "'" | xargs)
  server_port="${server_port:-50051}"
  if ! nc -z localhost "$server_port" 2>/dev/null; then
    echo -e "  ${DIM}duckport-server 未监听 :${server_port}${NC}\n"
    return
  fi

  while IFS= read -r inst; do
    local py cfg
    py=$(_instance_python "$inst")
    cfg="$INGESTORS_DIR/$inst/config.env"
    [[ -x "$py" && -f "$cfg" ]] || continue

    "$py" - "$inst" "$cfg" << 'PYEOF' 2>/dev/null || true
import sys, os, pandas as pd, logging
os.environ.setdefault("INGESTOR_ENV_FILE", sys.argv[2])
from binance_ingestor.config import DUCKPORT_ADDR, DUCKPORT_SCHEMA, KLINE_INTERVAL
from binance_ingestor.duckport_client import DuckportClient
for _h in logging.getLogger('binance_ingestor').handlers:
    _h.stream = sys.stderr
from datetime import datetime, timezone

inst = sys.argv[1]
dc = DuckportClient(addr=DUCKPORT_ADDR, schema=DUCKPORT_SCHEMA, interval=KLINE_INTERVAL)
now = datetime.now(timezone.utc)
try:
    wm = dc.read_table(DUCKPORT_SCHEMA, "watermark").to_pandas()
    for _, row in wm.iterrows():
        tname = row["table_name"]
        val = row["duck_time"]
        if pd.isna(val):
            print(f"  [{inst}] {tname:<22}: None")
            continue
        dt = pd.to_datetime(val).tz_localize(timezone.utc)
        age = now - dt
        h, r = divmod(int(age.total_seconds()), 3600)
        m = r // 60
        age_str = f"{h}h{m:02d}m" if h else f"{m}m"
        mark = "\033[0;32m✓\033[0m" if age.total_seconds() < 900 else "\033[1;33m⚠\033[0m"
        print(f"  [{inst}] {tname:<22}: {dt.strftime('%Y-%m-%d %H:%M')} UTC  {mark} {age_str} ago")
finally:
    dc.close()
PYEOF
  done <<< "$([ -z "$instances" ] && echo "" || echo "$instances")"
  echo ""
}

# ─── start / stop / restart ───────────────────────────────────────────────────

cmd_start() {
  _require_root
  local arg="${1:-server}"

  if [[ "$arg" == "all" ]] || [[ "$arg" == "server" ]]; then
    _svc_start "duckport-server"
    echo -e "  ${GREEN}✓${NC} duckport-server started"
    [[ "$arg" == "server" ]] && return
    sleep 2
  fi

  local instances
  instances=$(_resolve_instances "$arg")
  while IFS= read -r inst; do
    [[ -z "$inst" ]] && continue
    _svc_start "duckport-ingestor@$inst"
    echo -e "  ${GREEN}✓${NC} duckport-ingestor@$inst started"
  done <<< "$instances"
}

cmd_stop() {
  _require_root
  local arg="${1:-all}"

  if [[ "$arg" == "server" ]]; then
    _svc_stop "duckport-server"
    echo -e "  ${DIM}○${NC} duckport-server stopped"
    return
  fi

  local instances
  instances=$(_resolve_instances "$arg")
  while IFS= read -r inst; do
    [[ -z "$inst" ]] && continue
    _svc_stop "duckport-ingestor@$inst"
    echo -e "  ${DIM}○${NC} duckport-ingestor@$inst stopped"
  done <<< "$instances"

  if [[ "$arg" == "all" ]]; then
    _svc_stop "duckport-server"
    echo -e "  ${DIM}○${NC} duckport-server stopped"
  fi
}

cmd_restart() {
  _require_root
  local arg="${1:-all}"
  cmd_stop "$arg"
  sleep 1
  cmd_start "$arg"
}

# ─── logs ─────────────────────────────────────────────────────────────────────

cmd_logs() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    echo "用法: duckport logs <实例名>|server|all"; exit 1
  fi

  if [[ "$OS" == "Linux" ]]; then
    case "$target" in
      server)
        exec journalctl -u duckport-server -f --no-hostname -o short-iso ;;
      all)
        local units=("-u" "duckport-server")
        while IFS= read -r inst; do
          [[ -n "$inst" ]] && units+=("-u" "duckport-ingestor@$inst")
        done <<< "$(_list_instances)"
        exec journalctl "${units[@]}" -f --no-hostname -o short-iso ;;
      *)
        exec journalctl -u "duckport-ingestor@$target" -f --no-hostname -o short-iso ;;
    esac
  else
    # macOS：launchd 将 stdout/stderr 重定向到 LOG_DIR 下的文件
    case "$target" in
      server)
        exec tail -f "$LOG_DIR/server.log" "$LOG_DIR/server.err" ;;
      all)
        # 收集所有日志文件（server + 所有已注册实例）
        local log_files=("$LOG_DIR/server.log" "$LOG_DIR/server.err")
        while IFS= read -r inst; do
          [[ -n "$inst" ]] || continue
          [[ -f "$LOG_DIR/$inst.log" ]] && log_files+=("$LOG_DIR/$inst.log")
          [[ -f "$LOG_DIR/$inst.err" ]] && log_files+=("$LOG_DIR/$inst.err")
        done <<< "$(_list_instances)"
        exec tail -f "${log_files[@]}" ;;
      *)
        local lf="$LOG_DIR/$target.log"
        local ef="$LOG_DIR/$target.err"
        if [[ ! -f "$lf" && ! -f "$ef" ]]; then
          echo -e "${RED}找不到日志文件：$lf${NC}"
          echo "提示：服务必须已被启动过才会生成日志文件"
          exit 1
        fi
        local args=()
        [[ -f "$lf" ]] && args+=("$lf")
        [[ -f "$ef" ]] && args+=("$ef")
        exec tail -f "${args[@]}" ;;
    esac
  fi
}

# ─── list（registry 插件列表）────────────────────────────────────────────────

_registry_file() { echo "$REPO_DIR/ingestor/registry.json"; }

_registry_get() {
  local plugin="${1//_/-}"
  local field="$2"
  local reg
  reg=$(_registry_file)
  python3 -c "
import json
try:
    data = json.load(open('$reg'))
    print(data.get('$plugin', {}).get('$field', ''))
except Exception:
    pass
" 2>/dev/null
}

cmd_list() {
  local reg
  reg=$(_registry_file)
  if [[ ! -f "$reg" ]]; then
    echo -e "${RED}未找到插件注册表：$reg${NC}"; exit 1
  fi
  echo -e "\n${BOLD}可用插件${NC}  (注册表: $reg)\n"
  python3 -c "
import json
data = json.load(open('$reg'))
for name, info in data.items():
    installed = ''
    print(f'  \033[1m{name}\033[0m')
    print(f'    {info.get(\"description\",\"\")}')
    print(f'    repo: {info.get(\"repo\",\"\")}')
    print()
" 2>/dev/null || echo "  （无）"
  echo -e "用法: ${BOLD}duckport install <插件名>${NC}"
  echo ""
}

# ─── install（从 registry 安装插件实例）──────────────────────────────────────

cmd_install() {
  _require_root
  local plugin="${1:-}"
  [[ -n "$plugin" ]] || { echo "用法: duckport install <插件名>"; cmd_list; exit 1; }
  plugin="${plugin//_/-}"

  local reg
  reg=$(_registry_file)
  [[ -f "$reg" ]] || { echo -e "${RED}未找到插件注册表：$reg${NC}"; exit 1; }

  local repo exec_cmd default_inst desc
  repo=$(_registry_get "$plugin" repo)
  exec_cmd=$(_registry_get "$plugin" exec)
  default_inst=$(_registry_get "$plugin" default_instance)
  desc=$(_registry_get "$plugin" description)

  [[ -n "$repo" ]] || { echo -e "${RED}未知插件：$plugin${NC}\n"; cmd_list; exit 1; }

  echo -e "\n${BOLD}安装插件：$plugin${NC}"
  echo -e "  $desc"
  echo -e "  repo: $repo\n"

  read -rp "  实例名          (默认 ${default_inst:-$plugin}): " INST_NAME
  INST_NAME="${INST_NAME:-${default_inst:-$plugin}}"

  local inst_dir="$INGESTORS_DIR/$INST_NAME"
  local cfg="$inst_dir/config.env"

  if [[ -d "$inst_dir" ]]; then
    echo -e "${YELLOW}实例 '$INST_NAME' 已存在：$inst_dir${NC}"
    echo "如需重建，请先执行: duckport rm $INST_NAME"
    exit 1
  fi
  mkdir -p "$inst_dir"

  read -rp "  K 线周期        (默认 5m): " IV;   IV="${IV:-5m}"
  read -rp "  DATA_SOURCES    (默认 usdt_perp,usdt_spot): " DS; DS="${DS:-usdt_perp,usdt_spot}"
  read -rp "  并发数          (默认 2): " CONC;  CONC="${CONC:-2}"
  read -rp "  START_DATE      (默认 2021-01-01): " SD; SD="${SD:-2021-01-01}"
  read -rp "  PROXY_URL       (留空跳过): " PX

  cat > "$cfg" << EOF
# 实例：$INST_NAME  插件：$plugin
INGESTOR_EXEC=${exec_cmd:-$plugin}
KLINE_INTERVAL=${IV}
DATA_SOURCES=${DS}
CONCURRENCY=${CONC}
START_DATE=${SD}
PROXY_URL=${PX}
EOF

  # 安装 Python 包
  echo -e "\n  安装 Python 环境..."
  export PATH="$HOME/.local/bin:$PATH"
  local python_bin python_ver
  python_bin=$(command -v python3.12 2>/dev/null || command -v python3)
  python_ver=$("$python_bin" --version | grep -oE '[0-9]+\.[0-9]+'  | head -1)
  uv venv --python "$python_ver" "$inst_dir/.venv" -q

  local inst_py="$inst_dir/.venv/bin/python3"
  # 优先本地 checkout（开发模式），否则从 git 安装
  local local_src
  local_src="$(dirname "$REPO_DIR")/duckport-${plugin}"
  if [[ -f "$local_src/pyproject.toml" ]]; then
    echo -e "  使用本地源码：$local_src"
    _uv_install -e "$local_src" --python "$inst_py"
  else
    _uv_install "git+${repo}" --python "$inst_py"
  fi

  if [[ "$OS" == "Linux" ]]; then
    systemctl daemon-reload
    systemctl enable "duckport-ingestor@$INST_NAME" 2>/dev/null || true
  else
    # macOS：launchd 无模板 unit，为每个实例生成独立 plist
    local label="com.duckport.ingestor.$INST_NAME"
    cat > "$PLIST_DIR/${label}.plist" << PLISTEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${label}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${DEPLOY_BIN}/ingestor-run</string>
    <string>${INST_NAME}</string>
  </array>
  <key>RunAtLoad</key>
  <false/>
  <key>KeepAlive</key>
  <dict>
    <key>Crashed</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>10</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>${LOG_DIR}/${INST_NAME}.log</string>
  <key>StandardErrorPath</key>
  <string>${LOG_DIR}/${INST_NAME}.err</string>
  <key>WorkingDirectory</key>
  <string>${INGESTORS_DIR}/${INST_NAME}</string>
</dict>
</plist>
PLISTEOF
    echo -e "  ${GREEN}✓${NC} plist 已创建：$PLIST_DIR/${label}.plist"
  fi

  echo -e "\n  ${GREEN}✓${NC} 实例 '${INST_NAME}' 安装完成"
  echo -e "  配置文件：$cfg"
  echo -e "  编辑配置：${BOLD}duckport config $INST_NAME${NC}"
  echo -e "  启动服务：${BOLD}duckport start $INST_NAME${NC}"
}

# ─── config（打开实例配置文件）───────────────────────────────────────────────

cmd_config() {
  local name="${1:-}"
  [[ -n "$name" ]] || { echo "用法: duckport config <实例名>"; exit 1; }
  name="${name//_/-}"

  local cfg="$INGESTORS_DIR/$name/config.env"
  if [[ ! -f "$cfg" ]]; then
    echo -e "${RED}未找到实例配置：$cfg${NC}"
    echo "已注册实例："
    _list_instances | sed 's/^/  /'
    exit 1
  fi

  ${EDITOR:-nano} "$cfg"
}

# ─── rm（删除实例）───────────────────────────────────────────────────────────

cmd_rm() {
  _require_root
  local name="${1:-}"
  [[ -n "$name" ]] || { echo "用法: duckport rm <实例名>"; exit 1; }
  name="${name//_/-}"

  local inst_dir="$INGESTORS_DIR/$name"
  [[ -d "$inst_dir" ]] || { echo -e "${RED}实例 '$name' 不存在${NC}"; exit 1; }

  read -rp "确认删除实例 '$name'？[y/N] " CONFIRM
  [[ "$CONFIRM" =~ ^[Yy]$ ]] || { echo "已取消"; exit 0; }

  _svc_stop "duckport-ingestor@$name"
  if [[ "$OS" == "Linux" ]]; then
    systemctl disable "duckport-ingestor@$name" 2>/dev/null || true
  else
    rm -f "$PLIST_DIR/com.duckport.ingestor.${name}.plist"
  fi
  rm -rf "$inst_dir"
  echo -e "  ${GREEN}✓${NC} 实例 '$name' 已删除"
}

# ─── loadhist ─────────────────────────────────────────────────────────────────

cmd_loadhist() {
  _require_root
  local name="${1:-}"
  local instances

  if [[ -n "$name" ]]; then
    instances="$name"
  else
    instances=$(_list_instances)
    [[ -n "$instances" ]] || { echo -e "${RED}无已注册实例${NC}"; exit 1; }
  fi

  while IFS= read -r inst; do
    [[ -z "$inst" ]] && continue
    local py cfg
    py=$(_instance_python "$inst")
    cfg="$INGESTORS_DIR/$inst/config.env"
    [[ -x "$py" && -f "$cfg" ]] || { echo -e "${YELLOW}跳过 $inst（环境不完整）${NC}"; continue; }

    echo -e "\n${BOLD}▶ loadhist — $inst${NC}"
    echo -e "  ${YELLOW}⚠ 停止 ingestor 以独占 staging 表${NC}"
    _svc_stop "duckport-ingestor@$inst"

    INGESTOR_ENV_FILE="$cfg" \
      "$INGESTORS_DIR/$inst/.venv/bin/loadhist" && \
      echo -e "  ${GREEN}✓ loadhist 完成${NC}" || \
      echo -e "  ${RED}✗ loadhist 失败${NC}"

    echo -e "  ${YELLOW}提示：请手动执行 duckport start $inst 以恢复采集${NC}"
  done <<< "$instances"
}

# ─── update（更新插件）────────────────────────────────────────────────────────

cmd_update() {
  _require_root
  local name="${1:-}"
  [[ -n "$name" ]] || { echo "用法: duckport update <实例名>"; exit 1; }
  name="${name//_/-}"

  local inst_dir="$INGESTORS_DIR/$name"
  local cfg="$inst_dir/config.env"
  [[ -d "$inst_dir" ]] || { echo -e "${RED}实例 '$name' 不存在${NC}"; exit 1; }

  local inst_py="$inst_dir/.venv/bin/python3"
  [[ -x "$inst_py" ]] || { echo -e "${RED}实例 '$name' 的 venv 不完整，请重新执行 duckport install${NC}"; exit 1; }

  # 通过 INGESTOR_EXEC 反查 registry 中的插件名和 repo URL
  local exec_cmd
  exec_cmd=$(grep '^INGESTOR_EXEC=' "$cfg" 2>/dev/null | cut -d= -f2 | tr -d '"' || echo "")

  local plugin_name repo
  local reg
  reg=$(_registry_file)
  if [[ -f "$reg" ]]; then
    plugin_name=$(python3 -c "
import json
try:
    d = json.load(open('$reg'))
    for k, v in d.items():
        if v.get('exec','') == '$exec_cmd':
            print(k); break
except: pass
" 2>/dev/null)
    repo=$(python3 -c "
import json
try:
    d = json.load(open('$reg'))
    for v in d.values():
        if v.get('exec','') == '$exec_cmd':
            print(v.get('repo','')); break
except: pass
" 2>/dev/null)
  fi

  export PATH="$HOME/.local/bin:$PATH"
  echo -e "\n${BOLD}更新实例：$name${NC}  (exec=$exec_cmd)"

  local local_src
  local_src="$(dirname "$REPO_DIR")/duckport-${plugin_name:-$exec_cmd}"

  if [[ -f "$local_src/pyproject.toml" ]]; then
    echo -e "  ${CYAN}本地源码模式：$local_src${NC}"
    git -C "$local_src" pull --ff-only
    _uv_install -e "$local_src" --python "$inst_py"
  elif [[ -n "$repo" ]]; then
    echo -e "  ${CYAN}GitHub 模式：$repo${NC}"
    _uv_install --reinstall "git+${repo}" --python "$inst_py"
  else
    echo -e "${RED}无法确定插件来源（registry 中未找到 exec=$exec_cmd）${NC}"
    exit 1
  fi

  echo -e "  ${GREEN}✓${NC} 插件已更新"
  echo -e "  ${YELLOW}提示：请手动执行 duckport restart $name 以使新版本生效${NC}"
}

# ─── upgrade ──────────────────────────────────────────────────────────────────

cmd_upgrade() {
  _require_root
  [[ -d "$REPO_DIR/.git" ]] || { echo -e "${RED}未找到仓库：$REPO_DIR${NC}"; exit 1; }
  echo -e "${BOLD}升级环境...${NC}"
  git -C "$REPO_DIR" pull --ff-only
  bash "$REPO_DIR/deploy.sh"
  echo -e "\n  ${YELLOW}环境已更新，如需生效：${NC}"
  echo -e "  duckport restart"
}

# ─── help ─────────────────────────────────────────────────────────────────────

cmd_help() {
  echo -e "
${BOLD}duckport${NC} — duckport-rs 服务管理

${BOLD}插件管理：${NC}
  duckport ${CYAN}list${NC}                           列出 registry 中的可用插件
  duckport ${CYAN}install${NC} <插件名>               从 registry 安装插件（交互式）
  duckport ${CYAN}rm${NC}      <实例名>               删除实例
  duckport ${CYAN}update${NC}  <实例名>               更新插件并重启实例
  duckport ${CYAN}config${NC}  <实例名>               编辑实例配置文件

${BOLD}服务控制：${NC}
  duckport ${CYAN}status${NC}                        服务总览 + 数据水位
  duckport ${CYAN}start${NC}   [实例名|server|all]    启动（默认 server）
  duckport ${CYAN}stop${NC}    [实例名|all]           停止（默认 all）
  duckport ${CYAN}restart${NC} [实例名|all]           重启（默认 all）
  duckport ${CYAN}logs${NC}    <实例名|server|all>    实时日志

${BOLD}数据操作：${NC}
  duckport ${CYAN}loadhist${NC} [实例名]              补历史数据（默认所有实例）

${BOLD}维护：${NC}
  duckport ${CYAN}upgrade${NC}                        git pull + 重新配置环境

${BOLD}示例：${NC}
