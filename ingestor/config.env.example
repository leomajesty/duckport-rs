# duckport-rs server address
DUCKPORT_ADDR=localhost:50051

# Kline interval
KLINE_INTERVAL=5m

# Parquet archive directory (must be accessible to duckport-rs server)
PARQUET_DIR=data/pqt

# Data sources (comma-separated: usdt_perp, usdt_spot)
DATA_SOURCES=usdt_perp,usdt_spot

# Concurrency (affects WS listener group count and fetch parallelism)
CONCURRENCY=2

# Plan A: loadhist 默认将 PARQUET_DIR 下该市场全部 Parquet 写入热库
LOADHIST_FULL_HOT_LOAD=true
# 仅当 LOADHIST_FULL_HOT_LOAD=false 时，可选在导入后删除「最新」单个 Parquet 文件（旧脚本行为）
LOADHIST_DELETE_PARQUET_AFTER_LOAD=false

# Plan A: 默认不启用周期导出+删除。若需旧行为，设 true 且 duckport-server 设
# DUCKPORT_RETENTION_ENABLED=true
RETENTION_ENABLED=false

# 仅在 RETENTION_ENABLED=true 时参与调度；与 RETENTION_DAYS 配合使用
RETENTION_DAYS=7

# Start date for historical data
START_DATE=2024-01-01

# HTTP proxy for Binance API (leave empty if not needed)
PROXY_URL=

# Enable WebSocket mode (true/false)
ENABLE_WS=false
